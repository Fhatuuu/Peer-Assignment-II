# Function to calc the correlation matrix of some matrix
get_corr_mat <- function(X){
n <- nrow(X)
X_centered <- scale(X, scale = FALSE)  # centering
cov_mat <- (t(X_centered) %*% X_centered) / (n-1)
D <- diag(1 / sqrt(diag(cov_mat)))
return( D %*% cov_mat %*% D) # return corr matrix
}
# Getting corr for each time period
num_mats <- split(data[, setdiff(names(data), "TimePeriod")],data$TimePeriod)
corr_list <- lapply(num_mats, get_corr_mat)
