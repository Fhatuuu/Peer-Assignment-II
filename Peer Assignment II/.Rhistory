plot_ellipse <- function(Sigma, n = 200) {
if (!all(dim(Sigma) == c(2,2))) {
stop("Input matrix must be 2x2")
}
eig <- eigen(Sigma)
# Eigenvectors and eigenvalues
V <- eig$vectors
D <- diag(sqrt(eig$values))
# Transformation matrix
A <- V %*% D
# Unit circle
t <- seq(0, 2*pi, length.out = n)
circle <- rbind(cos(t), sin(t))
# Transform circle into ellipse
ellipse <- A %*% circle
# Plot
plot(ellipse[1,], ellipse[2,],
type = "l",
asp = 1,
xlab = "X",
ylab = "Y",
main = "Ellipse from 2x2 Matrix")
# Draw axes
arrows(0,0,
V[1,1]*sqrt(eig$values[1]),
V[2,1]*sqrt(eig$values[1]),
col="red", lwd=2)
arrows(0,0,
V[1,2]*sqrt(eig$values[2]),
V[2,2]*sqrt(eig$values[2]),
col="blue", lwd=2)
}
Sigma <- matrix(c(1,0,0,1), nrow = 2)
plot_ellipse(Sigma)
plot_ellipse(Sigma)
plot_ellipse <- function(Sigma, n = 200) {
if (!all(dim(Sigma) == c(2,2))) {
stop("Input matrix must be 2x2")
}
eig <- eigen(Sigma)
# Sort eigenvalues in descending order
ord <- order(eig$values, decreasing = TRUE)
values <- eig$values[ord]
vectors <- eig$vectors[, ord]
# Transformation matrix
A <- vectors %*% diag(sqrt(values))
# Unit circle
t <- seq(0, 2*pi, length.out = n)
circle <- rbind(cos(t), sin(t))
# Ellipse points
ellipse <- A %*% circle
plot(ellipse[1,], ellipse[2,],
type = "l",
asp = 1,
xlab = "X",
ylab = "Y",
main = "Ellipse from 2x2 Matrix")
# Axis endpoints
axis1 <- vectors[,1] * sqrt(values[1])
axis2 <- vectors[,2] * sqrt(values[2])
# Draw axes
arrows(0,0, axis1[1], axis1[2], col="red", lwd=2)
arrows(0,0, axis2[1], axis2[2], col="blue", lwd=2)
# Label eigenvalues slightly above arrows
text(axis1[1]*1.1, axis1[2]*1.1,
labels = paste0("λ1 = ", round(values[1],3)),
col="red")
text(axis2[1]*1.1, axis2[2]*1.1,
labels = paste0("λ2 = ", round(values[2],3)),
col="blue")
}
Sigma <- matrix(c(1,0,0,1), nrow = 2)
plot_ellipse(Sigma)
