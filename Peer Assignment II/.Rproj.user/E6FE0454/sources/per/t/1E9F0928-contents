```{r}
#| echo: false
#| message: false
#| warning: false
library(readr)
library(dplyr)
library(tidyverse)
library(ggplot2)
library(tidyr)
X <- read_csv("CA2.csv")

```


```{r}
#| echo: false
#| message: false
#| warning: false
# SVD on X
sv <- svd(X)

rank_approx <- function(s){
  A <- sv$u[,1:s] %*% diag(sv$d[1:s], nrow = s, ncol = s) %*% t(sv$v[,1:s])
  
  colnames(A) <- colnames(X)
  rownames(A) <- rownames(X)
  
  A
}

B <- lapply(1:12, rank_approx)
```

```{r}
#| echo: false
#| message: false
#| warning: false
error_mat <- lapply(1: 12, function(s){
  X - B[[s]]
})
```
Reporting on a dataset with 100 observations on 12 unknown variables, V1-V12. 

