library(foreach)
library(doParallel)
library(parallel)
B <- 10000
n <- 50
MC <- 20000
true_mean <- 1
B <- 10000
n <- 50
MC <- 20000
true_mean <- 1
boot <- function(i){
x <- rexp(n, rate = 1)
boot_means <- replicate(B, {
mean(sample(x, n, replace = TRUE))
})
CI <- quantile(boot_means, c(0.025, 0.975))
as.numeric(CI[1] <= true_mean & CI[2] >= true_mean )
}
cluster <- makeCluster(detectCores() - 1)
clusterExport(cluster, c("n", "B", "true_mean", "boot"))
results <- parApply(cluster, 1:MC, boot)
