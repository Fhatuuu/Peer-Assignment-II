B <- 10000
n <- 50
MC <- 20000
true_mean <- 1
boot <- function(m){
out <- numeric(m)
for(i in 1:m){
x <- rexp(n, rate = 1)
boot_means <- replicate(B, mean(sample(x, n, replace = TRUE)))
CI <- quantile(boot_means, c(0.025, 0.975))
out[i] <- (CI[1] <= true_mean & CI[2] >= true_mean)
}
out
}
cores <- detectCores() - 1
cluster <- makeCluster(cores)
clusterExport(cluster, c("n","B","true_mean","boot"))
# split work across cores
jobs <- rep(MC / cores, cores)
results <- parLapply(cluster, jobs, boot)
B <- 1000
n <- 50
MC <- 2000
true_mean <- 1
boot <- function(m){
out <- numeric(m)
for(i in 1:m){
x <- rexp(n, rate = 1)
boot_means <- replicate(B, mean(sample(x, n, replace = TRUE)))
CI <- quantile(boot_means, c(0.025, 0.975))
out[i] <- (CI[1] <= true_mean & CI[2] >= true_mean)
}
out
}
cores <- detectCores() - 1
cluster <- makeCluster(cores)
clusterExport(cluster, c("n","B","true_mean","boot"))
# split work across cores
jobs <- rep(MC / cores, cores)
results <- parLapply(cluster, jobs, boot)
stopCluster(cluster)
coverage <- mean(unlist(results))
coverage
round(coverage, 2)
B <- 1000
n <- 50
MC <- 20000
true_mean <- 1
cores <- parallel::detectCores() - 1
cl <- makeCluster(cores)
registerDoParallel(cl)
boot_fun <- function(){
x <- rexp(n, rate = 1)
boot_samples <- matrix(sample(x, n * B, replace = TRUE), nrow = n)
boot_means <- colMeans(boot_samples)
CI <- quantile(boot_means, c(0.025, 0.975))
as.numeric(CI[1] <= true_mean & CI[2] >= true_mean)
}
results <- foreach(i = 1:MC, .combine = c) %dopar% {
boot_fun()
}
stopCluster(cl)
coverage <- mean(results)
round(coverage, 2)
